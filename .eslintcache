ow flex-wrap mt-7'>\n            <div className='mr-4'>\n              <a href={`https://www.linkedin.com/in/${LINKEDIN_USERNAME}`} target='_blank' rel='noreferrer'>\n                <span className='mb-2 flex flex-row items-end border border-gray-500 p-2 rounded-lg text-sm'>\n                  <img src='./images/icons/linkedin.svg' alt='' width='24px' height='24px' className='mr-1' />\n                  LinkedIn\n                </span>\n              </a>\n            </div>\n\n            <div className='mr-4'>\n              <a href={`https://github.com/${GITHUB_USERNAME}`} target='_blank' rel='noreferrer'>\n                <span className='mb-2 flex flex-row items-end border border-gray-500 p-2 rounded-lg text-sm'>\n                  <img src='./images/icons/github.svg' alt='' width='24px' height='24px' className='mr-1' />\n                  GitHub\n                </span>\n              </a>\n            </div>\n\n            <div className='mr-4'>\n              <a href={RESUME_PATH} target='_blank' rel='noreferrer'>\n                <span className='mb-2 flex flex-row items-end border border-gray-500 p-2 rounded-lg text-sm'>\n                  <img src='./images/icons/resume1.png' alt='' className='mr-1'\n                    style={{\n                      width:\"24px\", height:\"24px\"\n                    }} \n                  />\n                  Resume\n                </span>\n              </a>\n            </div>\n\n          </div>\n        </div>\n\n        {/* <div className='bg-gray px-5 py-10 md:py-8 sm:p-8 my-2 md:rounded-lg shadow-lg  justify-between w-full  md:w-6/12 '>\n          <form className='flex flex-col space-y-3 m-auto w-full' name='contact' method='post'>\n            <input type='hidden' name='form-name' value='contact' />\n\n            <label htmlFor='name'>Name</label>\n            <input type='text' name='name' id='name' className='gradient' required></input>\n            <label htmlFor='email'>Email</label>\n            <input type='email' name='email' id='email' className='gradient' required></input>\n            <label htmlFor='message'>Message</label>\n            <textarea name='message' id='message' cols='25' rows='5' className='gradient' required></textarea>\n            <button type='submit' className='border border-gray-500 p-2 rounded-lg w-auto mr-auto shadow-md'>\n              Send Message\n            </button>\n          </form>\n        </div> */}\n      <div className='relative md:bottom-24 mr-auto ml-auto md:mr-auto md:ml-0 max-w-xs md:max-w-sm cursor-pointer' onClick={() => window.scroll(0, 0)}>\n        <picture>\n          <source srcSet='./images/rocket-320.webp 320w, ./images/rocket.webp 768w' type='image/webp' />\n          <source srcSet='./images/rocket.png' sizes='(min-width: 768px) 50vw, 100vw' type='image/png' />\n          <img width='500px' height='500px' loading='lazy' alt='red rocket flying' />\n        </picture>\n      </div>\n      </div>\n    </section>\n  );\n};\n\nexport default Contact;\n","/home/mohiyuddin/Documents/MyApps/react/portfolio-website/src/root.link.js",[],"/home/mohiyuddin/Documents/MyApps/react/portfolio-website/src/SkillData.js",[],"/home/mohiyuddin/Documents/MyApps/react/portfolio-website/src/ExData.js",[],"/home/mohiyuddin/Documents/MyApps/react/portfolio-website/src/projectData.js",[],"/home/mohiyuddin/Documents/MyApps/react/portfolio-website/src/components/Footer.js",[],{"ruleId":"67","replacedBy":"68"},{"ruleId":"69","replacedBy":"70"},{"ruleId":"71","severity":1,"message":"72","line":2,"column":10,"nodeType":"73","messageId":"74","endLine":2,"endColumn":17},{"ruleId":"71","severity":1,"message":"75","line":2,"column":19,"nodeType":"73","messageId":"74","endLine":2,"endColumn":27},{"ruleId":"71","severity":1,"message":"76","line":2,"column":29,"nodeType":"73","messageId":"74","endLine":2,"endColumn":39},{"ruleId":"71","severity":1,"message":"77","line":2,"column":58,"nodeType":"73","messageId":"74","endLine":2,"endColumn":67},{"